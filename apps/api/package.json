{
  "name": "@habit-app/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "prisma generate --schema=prisma/schema.dev.prisma && ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate --schema=prisma/schema.prisma && tsc",
    "start": "node dist/index.js",
    "start:migrate": "prisma migrate deploy && node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema=prisma/schema.dev.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=prisma/schema.dev.prisma",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push --schema=prisma/schema.dev.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.dev.prisma",
    "seed:demo": "ts-node -r dotenv/config src/scripts/seed-demo.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "prisma": "^6.19.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "zod": "^3.25.76"
  }
}
