generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  name          String
  refreshToken  String?
  onboardedAt   DateTime?
  createdAt     DateTime  @default(now())
  settings      String    @default("{}")

  habits             Habit[]
  timeEntries        TimeEntry[]
  insights           Insight[]
  stats              UserStats?
  achievementUnlocks AchievementUnlock[]
  challenges         ChallengeAssignment[]
}

model UserStats {
  userId                  String    @id
  xp                      Int       @default(0)
  level                   Int       @default(1)
  lifetimeCompletions     Int       @default(0)
  currentDailyStreak      Int       @default(0)
  longestDailyStreak      Int       @default(0)
  lastActiveDate          DateTime?
  streakFreezesAvailable  Int       @default(1)
  lastFreezeRefreshAt     DateTime?
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChallengeAssignment {
  id           String    @id @default(uuid())
  userId       String
  challengeKey String
  type         String
  periodKey    String
  startedAt    DateTime  @default(now())
  expiresAt    DateTime
  completedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, periodKey])
  @@index([userId])
}

model AchievementUnlock {
  id             String   @id @default(uuid())
  userId         String
  achievementKey String
  unlockedAt     DateTime @default(now())
  notifiedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementKey])
  @@index([userId])
}

// type: "good" | "bad"
model Habit {
  id             String   @id @default(uuid())
  userId         String
  name           String
  type           String
  frequency      Int
  targetDuration Int?
  trigger        String?
  replacementFor String?
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@index([userId])
}

model HabitLog {
  id        String   @id @default(uuid())
  habitId   String
  date      DateTime @db.Date
  completed Boolean  @default(false)
  duration  Int?
  note      String?
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
}

// category: "social" | "work" | "entertainment" | "productivity" | "other"
// source:   "manual" | "timer" | "extension"
model TimeEntry {
  id          String   @id @default(uuid())
  userId      String
  label       String
  category    String
  durationSec Int
  startedAt   DateTime
  endedAt     DateTime
  source      String   @default("manual")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

// type: "correlation" | "prediction" | "suggestion" | "alert"
model Insight {
  id        String   @id @default(uuid())
  userId    String
  type      String
  content   String
  data      String   @default("{}")
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dismissed])
}
